doctype html
html
  head
    title Essentials
    link(rel="stylesheet", href="/stylesheets/styles.css")
  body
    header
      h1 Essentials
      h3 Welcome #{username}!
      nav
        a(href="/products") All Products
        |   |  
        a(href="/cart") Cart
        |   |  
        if typeof username !== 'undefined'
          a(href="/logout") Logout
        else
          a(href="/login") Login

    .container
      aside.sidebar
        h3 Categories
        ul
          li
            a(href="/products/electronics") Electronics
          li
            a(href="/products/clothing") Clothing
          li
            a(href="/products/wellness") Wellness
          li
            a(href="/products/general") General

      main
        block content

    footer
      p &copy; #{new Date().getFullYear()} My Store
